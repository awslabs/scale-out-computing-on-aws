# Begin: Apply password policy settings to AWS Managed AD PSO

function apply_ad_password_policy {
  {% if not context.get("/configuration/UserDirectory/password_policy/enabled", true) %}
  log_info "Password policy updates disabled by configuration, skipping."
  return 0
  {% endif %}
  local DS_DOMAIN_NAME="{{ context.get("/configuration/UserDirectory/domain_name") }}"
  local DS_DOMAIN_DN=$(echo "${DS_DOMAIN_NAME}" | sed 's/\./,DC=/g' | sed 's/^/DC=/')
  local PSO_NAME="{{ context.get("/configuration/UserDirectory/password_policy/pso_name", "CustomerPSO-01") }}"
  local PSO_DN="CN=${PSO_NAME},CN=Password Settings Container,CN=System,${DS_DOMAIN_DN}"
  local AD_CACHE="/apps/edh/{{ context.get("/configuration/ClusterId") }}/shared/custom_automation/ad_automation"
  local DS_DOMAIN_ADMIN_USERNAME=$(cat "${AD_CACHE}/join_domain_user.cache")
  local DS_DOMAIN_ADMIN_PASSWORD_FILE="${AD_CACHE}/join_domain.cache"

  log_info "Using creds for bind user: ${DS_DOMAIN_ADMIN_USERNAME}"
  log_info "Target PSO: ${PSO_DN}"

  # Log configured values from context
  {% set attr_map = [
    ("max_password_age_days", "msDS-MaximumPasswordAge", 0, "days"),
    ("min_password_age_days", "msDS-MinimumPasswordAge", 1, "days"),
    ("min_password_length", "msDS-MinimumPasswordLength", 7, "int"),
    ("password_history_length", "msDS-PasswordHistoryLength", 24, "int"),
    ("lockout_threshold", "msDS-LockoutThreshold", 0, "int"),
    ("lockout_duration_minutes", "msDS-LockoutDuration", 30, "minutes"),
    ("lockout_observation_window_minutes", "msDS-LockoutObservationWindow", 30, "minutes"),
    ("complexity_enabled", "msDS-PasswordComplexityEnabled", true, "bool"),
    ("reversible_encryption", "msDS-PasswordReversibleEncryptionEnabled", false, "bool")
  ] %}
  {% for key, ldap_attr, default_val, unit in attr_map %}
  log_info "  Config: {{ key }} = {{ context.get("/configuration/UserDirectory/password_policy/" ~ key, default_val) }} ({{ unit }}, maps to {{ ldap_attr }})"
  {% endfor %}
  log_info "  Config: max_retries = {{ context.get("/configuration/UserDirectory/password_policy/max_retries", 10) }}"

  # Query current PSO settings before making changes
  log_info "Querying the current PSO settings from LDAP ..."
  local MAX_RETRIES={{ context.get("/configuration/UserDirectory/password_policy/max_retries", 10) }}
  local RETRY_COUNT=0
  local LDAP_QUERY_SUCCESS=false

  while [[ ${RETRY_COUNT} -lt ${MAX_RETRIES} ]]; do
    local QUERY_OUTPUT
    if QUERY_OUTPUT=$(ldapsearch -x -H "ldap://${DS_DOMAIN_NAME}" \
      -D "${DS_DOMAIN_ADMIN_USERNAME}" \
      -y "${DS_DOMAIN_ADMIN_PASSWORD_FILE}" \
      -b "${PSO_DN}" -s base "(objectClass=*)" \
      {% for key, ldap_attr, default_val, unit in attr_map %}{{ ldap_attr }} {% endfor %}2>/dev/null)
    then
      echo "${QUERY_OUTPUT}" | grep -i "msDS-" | while read line; do log_info "  Current: ${line}"; done
      LDAP_QUERY_SUCCESS=true
      break
    else
      RETRY_COUNT=$((RETRY_COUNT + 1))
      local BACKOFF=$(( 2 ** RETRY_COUNT > 60 ? 60 : 2 ** RETRY_COUNT ))
      if [[ ${RETRY_COUNT} -lt ${MAX_RETRIES} ]]; then
        log_warning "ldapsearch failed (attempt ${RETRY_COUNT}/${MAX_RETRIES}), retrying in ${BACKOFF}s ..."
        sleep ${BACKOFF}
      fi
    fi
  done

  if [[ "${LDAP_QUERY_SUCCESS}" != "true" ]]; then
    log_warning "Unable to query PSO after ${MAX_RETRIES} attempts. LDAP server may be unavailable. Skipping password policy update."
    return 0
  fi

  # Build LDIF dynamically from password_policy config
  local LDIF_FILE=$(mktemp /root/edh_ad_pso_update.XXXXXX.ldif)
  echo "dn: ${PSO_DN}" > "${LDIF_FILE}"
  echo "changetype: modify" >> "${LDIF_FILE}"

  local ATTR_COUNT=0

  # Tuple format: (yaml_key, ldap_attribute, default_value, unit)
  # Zero handling: max_password_age_days=0 means never expires (I64_MIN)
  #                all other time fields: 0 passes through as 0 (disabled/immediate)
  {% set ns = namespace(first=true) %}
  {% for key, ldap_attr, default_val, unit in attr_map %}
  {% set val = context.get("/configuration/UserDirectory/password_policy/" ~ key, default_val) %}
  {% set val = val | int if unit in ("days", "minutes", "int") else val %}
  {% if not ns.first %}
  echo "-" >> "${LDIF_FILE}"
  {% endif %}
  {% set ns.first = false %}
  echo "replace: {{ ldap_attr }}" >> "${LDIF_FILE}"
  {% if unit == "bool" %}
  echo "{{ ldap_attr }}: {{ "TRUE" if val else "FALSE" }}" >> "${LDIF_FILE}"
  {% elif unit == "days" %}
  {% if key == "max_password_age_days" and val == 0 %}
  echo "{{ ldap_attr }}: -9223372036854775808" >> "${LDIF_FILE}"
  {% elif val == 0 %}
  echo "{{ ldap_attr }}: 0" >> "${LDIF_FILE}"
  {% else %}
  echo "{{ ldap_attr }}: {{ val * -864000000000 }}" >> "${LDIF_FILE}"
  {% endif %}
  {% elif unit == "minutes" %}
  {% if val == 0 %}
  echo "{{ ldap_attr }}: 0" >> "${LDIF_FILE}"
  {% else %}
  echo "{{ ldap_attr }}: {{ val * -600000000 }}" >> "${LDIF_FILE}"
  {% endif %}
  {% else %}
  echo "{{ ldap_attr }}: {{ val }}" >> "${LDIF_FILE}"
  {% endif %}
  ATTR_COUNT=$((ATTR_COUNT + 1))
  {% endfor %}

  log_info "Applying password policy (${ATTR_COUNT} attributes) to PSO: ${PSO_NAME}"
  log_info "Full LDIF content:"
  cat "${LDIF_FILE}" | while read line; do log_info "  ${line}"; done

  # Apply LDIF with retry
  RETRY_COUNT=0
  local LDAP_MODIFY_SUCCESS=false

  while [[ ${RETRY_COUNT} -lt ${MAX_RETRIES} ]]; do
    if ldapmodify -x -H "ldap://${DS_DOMAIN_NAME}" \
      -D "${DS_DOMAIN_ADMIN_USERNAME}" \
      -y "${DS_DOMAIN_ADMIN_PASSWORD_FILE}" \
      -f "${LDIF_FILE}"
    then
      LDAP_MODIFY_SUCCESS=true
      break
    else
      RETRY_COUNT=$((RETRY_COUNT + 1))
      local BACKOFF=$(( 2 ** RETRY_COUNT > 60 ? 60 : 2 ** RETRY_COUNT ))
      if [[ ${RETRY_COUNT} -lt ${MAX_RETRIES} ]]; then
        log_warning "ldapmodify failed (attempt ${RETRY_COUNT}/${MAX_RETRIES}), retrying in ${BACKOFF}s ..."
        sleep ${BACKOFF}
      fi
    fi
  done

  if [[ "${LDAP_MODIFY_SUCCESS}" == "true" ]]; then
    log_info "Password policy applied successfully to ${PSO_NAME}, delaying 15 seconds for AD sync and verify..."
    sleep 15
    local VERIFY_OUTPUT
    VERIFY_OUTPUT=$(ldapsearch -x -H "ldap://${DS_DOMAIN_NAME}" \
      -D "${DS_DOMAIN_ADMIN_USERNAME}" \
      -y "${DS_DOMAIN_ADMIN_PASSWORD_FILE}" \
      -b "${PSO_DN}" -s base "(objectClass=*)" \
      {% for key, ldap_attr, default_val, unit in attr_map %}{{ ldap_attr }} {% endfor %}2>/dev/null) || true
    echo "${VERIFY_OUTPUT}" | grep -i "msDS-" | while read line; do log_info "  Verification Check: ${line}"; done
    log_info "Password Policy updated successfully to PSO: ${PSO_NAME}"
    # Cleanup the LDIF file if it was applied correctly
    rm -f "${LDIF_FILE}"
  else
    log_warning "Failed to apply password policy to ${PSO_NAME} after ${MAX_RETRIES} attempts. This is non-fatal, continuing bootstrap. LDIF retained at ${LDIF_FILE}"
  fi


}

# Now exec it
apply_ad_password_policy

# End: Apply password policy settings to AWS Managed AD PSO
